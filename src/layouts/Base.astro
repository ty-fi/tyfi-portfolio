---
import '../styles/a-editorial.css';
import '../styles/b-warmblog.css';
import '../styles/c-scholarly.css';
import '../styles/d-amber-terminal.css';
import '../styles/template-switcher.css';

export interface Props {
  title: string;
  description?: string;
  nav?: { label: string; href: string }[];
  path?: string;
}

const {
  title,
  description = 'Energy research, expert testimony, and analysis on the clean energy transition in the Southeast.',
  nav = [
    { label: 'Work', href: '/work' },
    { label: 'Press', href: '/press' },
    { label: 'About', href: '/about' },
    { label: 'Contact', href: '/contact' },
  ],
  path = Astro.url.pathname,
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Source+Serif+4:ital,wght@0,400;0,500;0,600;1,400;1,500&family=JetBrains+Mono:wght@400;500&family=Space+Mono:ital,wght@0,400;0,700;1,400&family=Orbitron:ital,wght@0,400;0,700;0,900;1,900&family=IBM+Plex+Serif:ital,wght@0,400;0,500;1,400&display=swap"
    />
    {/* Template switcher: read ?tpl= from URL, set body class accordingly.
        Runs before body renders to minimize flash of unstyled content. */}
    <script is:inline>
      (function () {
        try {
          var t = new URLSearchParams(window.location.search).get('tpl');
          var valid = ['a', 'b', 'c', 'd'];
          var cls = valid.indexOf(t) >= 0 ? t : 'a';
          document.documentElement.dataset.tpl = cls;
          // Set the body class as soon as body exists
          function apply() {
            if (document.body) {
              document.body.className = 'template-' + cls + '-page';
            }
          }
          apply();
          if (document.readyState === 'loading') {
            document.addEventListener('DOMContentLoaded', apply);
          }
        } catch (e) {}
      })();
    </script>
  </head>
  <body class="template-a-page">
    <header class="site-header">
      <div class="container">
        <a href="/" class="site-title">Tyler Fitch</a>
        <nav class="site-nav" aria-label="Primary">
          {nav.map((item) => (
            <a href={item.href} class={path === item.href || (item.href !== '/' && path.startsWith(item.href)) ? 'active' : ''}>
              {item.label}
            </a>
          ))}
        </nav>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <div class="container">
        <p>
          Tyler Fitch · Energy research and expert testimony
          <br />
          Hosted on <a href="https://pages.github.com">GitHub Pages</a>. Source available in the repo.
        </p>
        <p style="margin-top: 0.5rem; opacity: 0.7;">
          <a href="/?tpl=a">Editorial</a> ·
          <a href="/?tpl=b">Blog</a> ·
          <a href="/?tpl=c">Scholarly</a> ·
          <a href="/?tpl=d">Amber Terminal</a>
        </p>
      </div>
    </footer>
  </body>
</html>
