---
import Base from '../layouts/Base.astro';
import authorData from '../content/author/tyler.json';

const { bio_long, education, experience, current_role } = authorData;
const paragraphs = bio_long.split('\n\n');
---

<Base
  title={`About — ${authorData.name}`}
  description={`About ${authorData.name}: ${authorData.headline}`}
>
  <div class="container">
    <section class="about-header">
      <div>
        <h1>About</h1>
        <p class="tpl-meta-c">{current_role.title}, {current_role.org}</p>
      </div>
      {authorData.photo && <img src={`${import.meta.env.BASE_URL}${authorData.photo.replace(/^\//, '')}`} alt={authorData.name} class="portrait" />}
    </section>

    <section>
      {paragraphs.map((p) => <p>{p}</p>)}
    </section>

    <h2 class="tpl-h2-a tpl-h2-b">Experience</h2>
    <h2 class="tpl-h2-c">Experience</h2>

    <ul class="timeline">
      {experience.map((e) => (
        <li>
          <span class="when">{e.start}{e.end ? `–${e.end}` : ''}</span>
          <span class="what">
            <span class="tpl-strong-a tpl-strong-b"><strong>{e.title}</strong> <span class="where">· {e.org}</span></span>
            <span class="tpl-em-c"><em>{e.title}</em>, {e.org}</span>
          </span>
        </li>
      ))}
    </ul>

    <h2 class="tpl-h2-a tpl-h2-b">Education</h2>
    <h2 class="tpl-h2-c">Education</h2>

    <ul class="timeline">
      {education.map((ed) => (
        <li>
          <span class="when"></span>
          <span class="what">
            <span class="tpl-strong-a tpl-strong-b"><strong>{ed.degree}</strong> <span class="where">· {ed.school}</span>{ed.focus && <div class="where" style="font-size: 0.875rem;">{ed.focus}</div>}</span>
            <span class="tpl-em-c"><em>{ed.degree}</em>, {ed.school}.{ed.focus && <span class="where"> {ed.focus}.</span>}</span>
          </span>
        </li>
      ))}
    </ul>
  </div>
</Base>
